# Layer gateway
LAYER_GATEWAY_URL=http://localhost:8080
LAYER_GATEWAY_API_KEY=

# Product pipeline
TURBOPUFFER_NAMESPACE=amazon-products
EXTRACTION_PIPELINE_ID=hev-shop-extraction-jobs
PIPELINE_ID=hev-shop-product-images
DEFAULT_CATEGORY=Electronics
DISTANCE_METRIC=cosine_distance

# Local data and model caches. Product images are fetched in memory by the GPU
# worker and are not cached on local disk.
DATA_DIR=./data
DATASET_DIR=./data/dataset
MODEL_CACHE_DIR=./data/models
API_MODEL_CACHE_DIR=./data/models

# Models
CLIP_MODEL_NAME=openai/clip-vit-large-patch14
CLIP_DEVICE=auto

# Optional credentials
HF_TOKEN=

# Web app
HEV_SHOP_API_BASE=http://127.0.0.1:8090
