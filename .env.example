# Layer gateway
LAYER_GATEWAY_URL=http://localhost:8080

# Product image pipeline
TURBOPUFFER_NAMESPACE=amazon-products
EXTRACTION_PIPELINE_ID=hev-shop-extraction-jobs
PIPELINE_ID=hev-shop-product-images
DEFAULT_CATEGORY=Electronics
DISTANCE_METRIC=cosine_distance

# Review fan-out pipeline
REVIEWS_PIPELINE_ID=hev-shop-reviews
REVIEWS_AGGREGATE_PIPELINE_ID=hev-shop-review-tags
REVIEWS_NAMESPACE_BASE=amazon-reviews
REVIEWS_NAMESPACE_SHARD_COUNT=16

# Local data and model caches
DATA_DIR=./data
DATASET_DIR=./data/dataset
IMAGE_DIR=./data/images
MODEL_CACHE_DIR=./data/models

# Models
CLIP_MODEL_NAME=openai/clip-vit-large-patch14
CLIP_DEVICE=auto
REVIEW_EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-8B
REVIEW_EMBEDDING_DEVICE=auto

# Optional credentials
HF_TOKEN=
OPENROUTER_API_KEY=

# Web app
HEV_SHOP_API_BASE=http://127.0.0.1:8090
