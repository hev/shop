.DS_Store

# Local env
.env
.env.*
!.env.example

# Go
/hev-shop

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Runtime data
data/

# Next.js
web/.next/
web/node_modules/
web/tsconfig.tsbuildinfo

# Build output
dist/
build/

# Exception: the vendored hev layer TypeScript client ships its build. The web
# image bundles it at `next build` time, so its dist/ is tracked despite the
# global dist/ ignore above. Refresh with scripts/sync-ts-client.sh.
!app/vendor/hevlayer/dist/
!app/vendor/hevlayer/dist/**
