{
  "name": "hevlayer",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the hevlayer gateway",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc --outDir .tmp-test && node --test .tmp-test/test/client.test.js"
  },
  "dependencies": {}
}
