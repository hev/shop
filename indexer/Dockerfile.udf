ARG BASE_IMAGE=python:3.12-slim
FROM ${BASE_IMAGE}

# Slim worker image for the backfill-images UDF. Skips the indexer's CLIP
# and Qwen wheels (no torch, no transformers, no model bake) — the UDF only
# needs httpx + the hevlayer SDK. Final image is ~120 MB vs. ~16 GB for the
# default indexer image.

ENV PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Pass the sibling SDK with BuildKit (same pattern as indexer/Dockerfile):
#   --build-context layer_client=../layer/clients/python
COPY --from=layer_client . /layer/clients/python

COPY indexer/requirements-udf.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY indexer/app/udfs ./app/udfs
COPY indexer/app/__init__.py ./app/__init__.py

CMD ["python", "-m", "app.udfs.backfill_images"]
