{
  "components": {
    "schemas": {
      "BackfillRequest": {
        "properties": {
          "asins": {
            "description": "Optional explicit ASIN list. When provided, product_limit is ignored. ASINs must belong to the given category \u2014 the HF dataset is sharded by category, so reviews are looked up in that file.",
            "items": {
              "type": "string"
            },
            "nullable": true,
            "title": "Asins",
            "type": "array"
          },
          "category": {
            "description": "HF dataset category (e.g., Electronics)",
            "title": "Category",
            "type": "string"
          },
          "max_total_reviews": {
            "description": "Global cap on reviews staged across the job.",
            "nullable": true,
            "title": "Max Total Reviews",
            "type": "integer"
          },
          "namespace": {
            "description": "Product namespace (defaults to settings.namespace).",
            "nullable": true,
            "title": "Namespace",
            "type": "string"
          },
          "pipeline_id": {
            "description": "Product pipeline id (defaults to settings.default_pipeline_id).",
            "nullable": true,
            "title": "Pipeline Id",
            "type": "string"
          },
          "product_limit": {
            "default": 1000,
            "description": "When asins is omitted, cap how many products to read from the HF dataset for the category. -1 = unlimited.",
            "title": "Product Limit",
            "type": "integer"
          },
          "reviews_per_product": {
            "description": "Cap reviews staged per ASIN. Defaults to the server's REVIEW_RECENT_CAP_PER_PRODUCT setting.",
            "nullable": true,
            "title": "Reviews Per Product",
            "type": "integer"
          },
          "stages": {
            "description": "Subset of ['embed','classify','aggregate']. Defaults to all three. 'embed'/'classify' stage review work items; 'aggregate' re-runs the product-level tag rollup for the affected ASINs.",
            "items": {
              "type": "string"
            },
            "nullable": true,
            "title": "Stages",
            "type": "array"
          }
        },
        "required": [
          "category"
        ],
        "title": "BackfillRequest",
        "type": "object"
      },
      "BackfillResponse": {
        "properties": {
          "asin_count": {
            "nullable": true,
            "title": "Asin Count",
            "type": "integer"
          },
          "category": {
            "title": "Category",
            "type": "string"
          },
          "job_id": {
            "title": "Job Id",
            "type": "string"
          },
          "max_total_reviews": {
            "nullable": true,
            "title": "Max Total Reviews",
            "type": "integer"
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          },
          "pipeline_id": {
            "title": "Pipeline Id",
            "type": "string"
          },
          "product_limit": {
            "title": "Product Limit",
            "type": "integer"
          },
          "reviews_per_product": {
            "nullable": true,
            "title": "Reviews Per Product",
            "type": "integer"
          },
          "stages": {
            "items": {
              "type": "string"
            },
            "title": "Stages",
            "type": "array"
          }
        },
        "required": [
          "job_id",
          "pipeline_id",
          "namespace",
          "category",
          "product_limit",
          "stages"
        ],
        "title": "BackfillResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "IndexCategoryResponse": {
        "properties": {
          "category": {
            "title": "Category",
            "type": "string"
          },
          "count": {
            "title": "Count",
            "type": "integer"
          },
          "jobs_created": {
            "title": "Jobs Created",
            "type": "integer"
          }
        },
        "required": [
          "category",
          "count",
          "jobs_created"
        ],
        "title": "IndexCategoryResponse",
        "type": "object"
      },
      "IndexRequest": {
        "properties": {
          "categories": {
            "description": "Optional multi-category fan-out. Overrides category unless category is explicitly merged by the caller.",
            "items": {
              "type": "string"
            },
            "nullable": true,
            "title": "Categories",
            "type": "array"
          },
          "category": {
            "nullable": true,
            "title": "Category",
            "type": "string"
          },
          "count": {
            "default": 100,
            "description": "-1 indexes all rows in one job",
            "title": "Count",
            "type": "integer"
          },
          "job_size": {
            "nullable": true,
            "title": "Job Size",
            "type": "integer"
          },
          "namespace": {
            "nullable": true,
            "title": "Namespace",
            "type": "string"
          },
          "pipeline_id": {
            "nullable": true,
            "title": "Pipeline Id",
            "type": "string"
          }
        },
        "title": "IndexRequest",
        "type": "object"
      },
      "IndexResponse": {
        "properties": {
          "categories": {
            "items": {
              "$ref": "#/components/schemas/IndexCategoryResponse"
            },
            "title": "Categories",
            "type": "array"
          },
          "category": {
            "title": "Category",
            "type": "string"
          },
          "count": {
            "title": "Count",
            "type": "integer"
          },
          "jobs_created": {
            "title": "Jobs Created",
            "type": "integer"
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          },
          "pipeline_id": {
            "title": "Pipeline Id",
            "type": "string"
          }
        },
        "required": [
          "pipeline_id",
          "namespace",
          "category",
          "count",
          "jobs_created"
        ],
        "title": "IndexResponse",
        "type": "object"
      },
      "StatusResponse": {
        "properties": {
          "extraction": {
            "additionalProperties": true,
            "title": "Extraction",
            "type": "object"
          },
          "jobs": {
            "additionalProperties": {
              "type": "integer"
            },
            "title": "Jobs",
            "type": "object"
          },
          "layer": {
            "additionalProperties": true,
            "title": "Layer",
            "type": "object"
          },
          "pipeline_id": {
            "title": "Pipeline Id",
            "type": "string"
          }
        },
        "required": [
          "pipeline_id",
          "layer",
          "jobs"
        ],
        "title": "StatusResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "hev-shop indexer",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/backfill": {
      "post": {
        "description": "Enqueue a backfill job that re-stages reviews (and optionally re-runs\naggregation) for products already in the namespace. The CPU extraction\nworker picks the job up and uses the layer-gateway pipelines that the\nreview-embed / review-classify / review-aggregate workers already consume.",
        "operationId": "backfill_backfill_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BackfillRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackfillResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Backfill"
      }
    },
    "/healthz": {
      "get": {
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Healthz Healthz Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Healthz"
      }
    },
    "/index": {
      "post": {
        "operationId": "index_products_index_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IndexRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Index Products"
      }
    },
    "/status": {
      "get": {
        "operationId": "status_status_get",
        "parameters": [
          {
            "in": "query",
            "name": "pipeline_id",
            "required": false,
            "schema": {
              "nullable": true,
              "title": "Pipeline Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Status"
      }
    }
  }
}
