{
  "components": {
    "schemas": {
      "CategoryBucket": {
        "properties": {
          "doc_count": {
            "title": "Doc Count",
            "type": "integer"
          },
          "value": {
            "title": "Value",
            "type": "string"
          }
        },
        "required": [
          "value",
          "doc_count"
        ],
        "title": "CategoryBucket",
        "type": "object"
      },
      "CountInfo": {
        "description": "Result of a /v2/namespaces/{ns}/scans radius (`ann`) count. `bounded=True`\nmeans one or more shards saturated their top_k cap on this round, so `count`\nis a lower bound. `approximate=True` means ANN recall makes the radius\nmembership itself approximate.",
        "properties": {
          "approximate": {
            "default": false,
            "title": "Approximate",
            "type": "boolean"
          },
          "bounded": {
            "title": "Bounded",
            "type": "boolean"
          },
          "count": {
            "title": "Count",
            "type": "integer"
          },
          "layer_perf": {
            "$ref": "#/components/schemas/LayerPerf",
            "nullable": true
          },
          "max_distance": {
            "title": "Max Distance",
            "type": "number"
          },
          "shards_saturated": {
            "default": 0,
            "title": "Shards Saturated",
            "type": "integer"
          },
          "shards_total": {
            "default": 0,
            "title": "Shards Total",
            "type": "integer"
          },
          "timed_out": {
            "default": false,
            "title": "Timed Out",
            "type": "boolean"
          }
        },
        "required": [
          "count",
          "bounded",
          "max_distance"
        ],
        "title": "CountInfo",
        "type": "object"
      },
      "DropInfo": {
        "properties": {
          "product_count": {
            "title": "Product Count",
            "type": "integer"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "stable_as_of": {
            "nullable": true,
            "title": "Stable As Of",
            "type": "integer"
          }
        },
        "required": [
          "run_id",
          "product_count"
        ],
        "title": "DropInfo",
        "type": "object"
      },
      "DropsResponse": {
        "properties": {
          "drops": {
            "items": {
              "$ref": "#/components/schemas/DropInfo"
            },
            "title": "Drops",
            "type": "array"
          },
          "layer_perf": {
            "$ref": "#/components/schemas/LayerPerf",
            "nullable": true
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          },
          "stable_as_of": {
            "nullable": true,
            "title": "Stable As Of",
            "type": "integer"
          }
        },
        "required": [
          "namespace",
          "drops"
        ],
        "title": "DropsResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LayerPerf": {
        "description": "One Layer gateway round-trip's timing + cache disposition,\nsurfaced to the UI so the showcase can render `42ms \u00b7 cache hit`\ninline. `cache_status` is the gateway's `x-layer-cache` header\n(`\"hit\"`, `\"miss\"`, or `\"miss-on-error\"`); `None` when the gateway\ndidn't attach the header \u2014 the `query` endpoint doesn't go through\nthe document cache, so query perfs always have `cache_status=None`.",
        "properties": {
          "cache_status": {
            "nullable": true,
            "title": "Cache Status",
            "type": "string"
          },
          "latency_ms": {
            "title": "Latency Ms",
            "type": "integer"
          }
        },
        "required": [
          "latency_ms"
        ],
        "title": "LayerPerf",
        "type": "object"
      },
      "MetaResponse": {
        "properties": {
          "categories": {
            "items": {
              "$ref": "#/components/schemas/CategoryBucket"
            },
            "title": "Categories",
            "type": "array"
          },
          "is_stable": {
            "default": false,
            "title": "Is Stable",
            "type": "boolean"
          },
          "layer_perf": {
            "$ref": "#/components/schemas/LayerPerf",
            "description": "Gateway round-trip timing for the namespace metadata fetch (not the category snapshot).",
            "nullable": true
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          },
          "stable_as_of": {
            "nullable": true,
            "title": "Stable As Of",
            "type": "integer"
          },
          "vectors": {
            "title": "Vectors",
            "type": "integer"
          }
        },
        "required": [
          "namespace",
          "vectors",
          "categories"
        ],
        "title": "MetaResponse",
        "type": "object"
      },
      "ProductResponse": {
        "properties": {
          "asin": {
            "title": "Asin",
            "type": "string"
          },
          "attributes": {
            "additionalProperties": true,
            "title": "Attributes",
            "type": "object"
          },
          "layer_perf": {
            "$ref": "#/components/schemas/LayerPerf",
            "description": "Gateway round-trip timing for the document fetch. `cache_status` = 'hit' means Aerospike served the document without touching turbopuffer.",
            "nullable": true
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          }
        },
        "required": [
          "asin",
          "namespace"
        ],
        "title": "ProductResponse",
        "type": "object"
      },
      "RecommendRequest": {
        "properties": {
          "asin": {
            "description": "Seed product ASIN",
            "minLength": 1,
            "title": "Asin",
            "type": "string"
          },
          "category": {
            "nullable": true,
            "title": "Category",
            "type": "string"
          },
          "include_attributes": {
            "items": {
              "type": "string"
            },
            "nullable": true,
            "title": "Include Attributes",
            "type": "array"
          },
          "namespace": {
            "nullable": true,
            "title": "Namespace",
            "type": "string"
          },
          "top_k": {
            "default": 10,
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Top K",
            "type": "integer"
          }
        },
        "required": [
          "asin"
        ],
        "title": "RecommendRequest",
        "type": "object"
      },
      "RecommendResponse": {
        "properties": {
          "asin": {
            "title": "Asin",
            "type": "string"
          },
          "hits": {
            "items": {
              "$ref": "#/components/schemas/SearchHit"
            },
            "title": "Hits",
            "type": "array"
          },
          "layer_perf": {
            "$ref": "#/components/schemas/LayerPerf",
            "nullable": true
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          },
          "next_cursor": {
            "nullable": true,
            "title": "Next Cursor",
            "type": "string"
          },
          "stable_as_of": {
            "nullable": true,
            "title": "Stable As Of",
            "type": "integer"
          }
        },
        "required": [
          "asin",
          "namespace",
          "hits"
        ],
        "title": "RecommendResponse",
        "type": "object"
      },
      "SearchHit": {
        "properties": {
          "attributes": {
            "additionalProperties": true,
            "title": "Attributes",
            "type": "object"
          },
          "dist": {
            "nullable": true,
            "title": "Dist",
            "type": "number"
          },
          "id": {
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "title": "SearchHit",
        "type": "object"
      },
      "SearchRequest": {
        "properties": {
          "catalog_run_id": {
            "description": "Filter results to a specific catalog drop/run id.",
            "nullable": true,
            "title": "Catalog Run Id",
            "type": "string"
          },
          "category": {
            "nullable": true,
            "title": "Category",
            "type": "string"
          },
          "cursor": {
            "description": "Opaque pagination cursor from a prior /search response's next_cursor. Re-send the same query/filters/top_k to keep paging consistent; the gateway re-applies the consistency watermark.",
            "nullable": true,
            "title": "Cursor",
            "type": "string"
          },
          "include_attributes": {
            "items": {
              "type": "string"
            },
            "nullable": true,
            "title": "Include Attributes",
            "type": "array"
          },
          "max_distance": {
            "default": 0.4,
            "description": "Cosine-distance ceiling for with_count. 0.4 is tight (\"results worth showing\"); raise toward 1.0 for looser totals.",
            "maximum": 2.0,
            "minimum": 0.0,
            "title": "Max Distance",
            "type": "number"
          },
          "namespace": {
            "nullable": true,
            "title": "Namespace",
            "type": "string"
          },
          "query": {
            "description": "Free-text search query. May be empty only when catalog_run_id is set, which browses that catalog drop without vector ranking.",
            "minLength": 0,
            "title": "Query",
            "type": "string"
          },
          "top_k": {
            "default": 10,
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Top K",
            "type": "integer"
          },
          "with_count": {
            "default": false,
            "description": "If true, fan out an extra /v2/namespaces/{ns}/scans radius (`ann`) count against the same query vector + filters to estimate how many docs sit within max_distance. Costs one extra round-trip.",
            "title": "With Count",
            "type": "boolean"
          }
        },
        "required": [
          "query"
        ],
        "title": "SearchRequest",
        "type": "object"
      },
      "SearchResponse": {
        "properties": {
          "count": {
            "$ref": "#/components/schemas/CountInfo",
            "description": "Set when the caller requested with_count.",
            "nullable": true
          },
          "hits": {
            "items": {
              "$ref": "#/components/schemas/SearchHit"
            },
            "title": "Hits",
            "type": "array"
          },
          "layer_perf": {
            "$ref": "#/components/schemas/LayerPerf",
            "description": "Gateway round-trip timing for the query call.",
            "nullable": true
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          },
          "next_cursor": {
            "description": "Opaque cursor for the next page. Present iff the gateway returned a full top_k (i.e. there may be more results). Pass it back as `cursor` on the next /search call alongside the same filters.",
            "nullable": true,
            "title": "Next Cursor",
            "type": "string"
          },
          "query": {
            "title": "Query",
            "type": "string"
          },
          "stable_as_of": {
            "description": "Epoch-ms watermark \u2014 results reflect everything indexed at or before this timestamp. None until the gateway's consistency watcher has observed a clean snapshot for the namespace.",
            "nullable": true,
            "title": "Stable As Of",
            "type": "integer"
          }
        },
        "required": [
          "query",
          "namespace",
          "hits"
        ],
        "title": "SearchResponse",
        "type": "object"
      },
      "TrendingEntry": {
        "description": "One materialized trending row, read back from `<ns>-trending` (RFC 0040).\n\nPopulated by the indexer reduce (`indexer/trending.py`); this service only\nreads it. `ndcg` is 0 in frequency mode (Phase 1).",
        "properties": {
          "count": {
            "title": "Count",
            "type": "integer"
          },
          "ndcg": {
            "default": 0.0,
            "title": "Ndcg",
            "type": "number"
          },
          "query": {
            "title": "Query",
            "type": "string"
          },
          "sample_top_ids": {
            "items": {
              "type": "string"
            },
            "title": "Sample Top Ids",
            "type": "array"
          },
          "score": {
            "title": "Score",
            "type": "number"
          }
        },
        "required": [
          "query",
          "count",
          "score"
        ],
        "title": "TrendingEntry",
        "type": "object"
      },
      "TrendingResponse": {
        "properties": {
          "entries": {
            "items": {
              "$ref": "#/components/schemas/TrendingEntry"
            },
            "title": "Entries",
            "type": "array"
          },
          "layer_perf": {
            "$ref": "#/components/schemas/LayerPerf",
            "nullable": true
          },
          "mode": {
            "default": "frequency",
            "description": "'frequency' (Phase 1, volume only) or 'quality' (Phase 2, volume \u00d7 NDCG). The storefront explainer reads this so it never claims a quality signal that isn't being computed.",
            "title": "Mode",
            "type": "string"
          },
          "namespace": {
            "title": "Namespace",
            "type": "string"
          },
          "stable_as_of": {
            "nullable": true,
            "title": "Stable As Of",
            "type": "integer"
          }
        },
        "required": [
          "namespace",
          "entries"
        ],
        "title": "TrendingResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "hev-shop search",
    "version": "0.1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/drops": {
      "get": {
        "description": "Recent catalog runs discovered from the `catalog_run_id` vector field.",
        "operationId": "drops_drops_get",
        "parameters": [
          {
            "in": "query",
            "name": "namespace",
            "required": false,
            "schema": {
              "nullable": true,
              "title": "Namespace",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 7,
              "maximum": 100,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DropsResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Drops"
      }
    },
    "/healthz": {
      "get": {
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Healthz Healthz Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Healthz"
      }
    },
    "/meta": {
      "get": {
        "description": "Fan out to layer-gateway for namespace shape:\n- /v2/namespaces/{ns}/metadata \u2192 row count + freshness watermark\n- on-demand snapshot on `category` \u2192 filterable category list",
        "operationId": "meta_meta_get",
        "parameters": [
          {
            "in": "query",
            "name": "namespace",
            "required": false,
            "schema": {
              "nullable": true,
              "title": "Namespace",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetaResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Meta"
      }
    },
    "/product/{asin}": {
      "get": {
        "operationId": "product_product__asin__get",
        "parameters": [
          {
            "in": "path",
            "name": "asin",
            "required": true,
            "schema": {
              "title": "Asin",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Product"
      }
    },
    "/recommend": {
      "post": {
        "description": "Visual-similarity recommendations seeded by an existing product ASIN.\n\nUses Layer's `nearest_to_id` query mode: the gateway looks up the seed\ndocument's stored vector and runs the nearest-neighbor query in one call.\nThe seed ASIN itself is filtered out so callers don't get the seed back\nas its own first hit.",
        "operationId": "recommend_recommend_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Recommend"
      }
    },
    "/search": {
      "post": {
        "operationId": "search_search_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Search"
      }
    },
    "/search/trending": {
      "get": {
        "operationId": "trending_search_trending_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 12,
              "maximum": 50,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrendingResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Trending"
      }
    }
  }
}
